<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - SoftSynth</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.6;
            margin: 0;
            padding: 0;
            color: #333;
            background-color: #fafafa;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            background-color: #fff;
            box-shadow: 0 0 10px rgba(0,0,0,0.05);
            min-height: 100vh;
        }
        #site-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 1rem;
        }
        #midheader h1 {
            margin: 0;
            font-size: 2em;
        }
        #midheader h2 {
            margin: 0;
            font-size: 1.2em;
            color: #666;
            font-weight: normal;
        }
        nav {
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #eaeaea;
        }
        nav ul {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            gap: 20px;
        }
        nav a {
            text-decoration: none;
            color: #0066cc;
            font-weight: 500;
        }
        nav a[aria-current="page"] {
            color: #333;
            text-decoration: underline;
        }
        main img {
            max-width: 100%;
            height: auto;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div id="site-header">
                <div id="leftheader">
                    <a href="{{ '/' | url }}">
                        <img src="{{ '/images/softsynth_logo.png' | url }}" alt="SoftSynth Logo" width="200" height="100" border="0">
                    </a>
                </div>
                <div id="midheader">
                    <h1>SoftSynth</h1>
                    <h2>... music and computers ...</h2>
                </div>
            </div>
            <nav>
                {% set navPages = collections.all | eleventyNavigation %}
                <ul>
                {%- for entry in navPages %}
                    <li>
                        <a href="{{ entry.url | url }}"{% if entry.url == page.url %} aria-current="page"{% endif %}>
                            {{ entry.title }}
                        </a>
                    </li>
                {%- endfor %}
                </ul>
            </nav>
        </header>

        <main>
            <h2>{{ title }}</h2>
            {{ content | safe }}
        </main>
        
        <footer>
            <p>&copy; {{ page.date.getFullYear() }} SoftSynth.com. Generated with Eleventy.</p>
        </footer>
    </div>
</body>
</html>
